# Create a copy of this file and name it .env
OPENAI_API_KEY="sk-..."
MISTRAL_API_KEY="..."
NEO4J_URI="neo4j+s://..."
NEO4J_USERNAME=""
NEO4J_PASSWORD=""
NEO4J_DATABASE=""

# Optional: OCR configuration
# OCR_MIN_CONFIDENCE=80.0  # Tesseract confidence threshold (0-100). Below this, falls back to Mistral OCR

# Optional: Knowledge Graph schema generation configuration
# KG_MAX_NODE_TYPES=10            # Max node types for LLM-generated schema
# KG_MAX_RELATIONSHIP_TYPES=20    # Max relationship types for LLM-generated schema
# KG_SCHEMA_SAMPLE_SIZE=8000      # Chars of sample text to use for schema generation